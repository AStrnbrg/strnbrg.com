---
const rooms = [
  {
    label: 'the company',
    title: 'for founders and operators',
    copy: 'I advise companies building Bitcoin, financial or technology infrastructure when the next step requires sharper positioning, capital strategy, client propositions or execution support.'
  },
  {
    label: 'the capital',
    title: 'for investors and institutions',
    copy: 'I work with investors, family offices and financial institutions trying to understand where value accrues across Bitcoin, infrastructure and adjacent technology, and what that implies for allocation.'
  }
];

const practiceAreas = [
  {
    number: '01',
    title: 'strategy',
    copy: 'Clarifying what the business is becoming, who it is for, why now, and how to say that without flattening it.'
  },
  {
    number: '02',
    title: 'capital',
    copy: 'Investor materials, market maps, treasury questions and the logic that connects a long-term thesis with a practical capital decision.'
  },
  {
    number: '03',
    title: 'institutions',
    copy: 'Client propositions, stakeholder maps and preparation for serious financial counterparties, where trust, risk and timing matter.'
  },
  {
    number: '04',
    title: 'operating intelligence',
    copy: 'Portfolio maps, decision systems and AI-enabled workflows that keep information current without replacing judgment.'
  }
];

const siteUrl = 'https://www.strnbrg.com/';
const pageTitle = 'Arnold Sternberg | Bitcoin-centered advisory';
const pageDescription = 'Arnold Sternberg advises founders, investors and institutions where Bitcoin, capital and technology infrastructure meet.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f3efe6" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content="https://www.strnbrg.com/images/arnold-sternberg-bw.png" />
    <meta property="og:image:alt" content="Arnold Sternberg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="https://www.strnbrg.com/images/arnold-sternberg-bw.png" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main>
      <section class="hero hero-quiet" aria-labelledby="hero-title">
        <nav class="topbar" aria-label="Primary navigation">
          <a class="mark wordmark" href="#top" aria-label="Arnold Sternberg home">STRNBRG</a>
          <div class="navlinks">
            <a href="#work">Work</a>
            <a href="#practice">Practice</a>
            <a href="#about">About</a>
            <a href="#contact">Contact</a>
          </div>
        </nav>

        <div class="hero-grid hero-single" id="top">
          <div class="hero-copy">
            <p class="eyebrow">Bitcoin-centered entrepreneur · capital strategy · finance and infrastructure</p>
            <h1 id="hero-title">Advisory work where Bitcoin, capital and technology infrastructure meet.</h1>
            <p class="lead">I advise a limited number of founders, investors and institutions on the work between thesis and execution: positioning, capital strategy, client propositions, treasury questions, partnerships and operating systems.</p>
            <div class="hero-actions">
              <a class="button" href="mailto:info@strnbrg.com?subject=Strategic%20conversation">Start a conversation</a>
              <a class="text-link" href="#practice">See the practice</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section intro thesis" aria-label="Thesis and execution">
        <div class="intro-card">
          <p>A good thesis is not enough. It has to survive clients, capital, timing, regulation, internal politics, risk questions and execution.</p>
        </div>
      </section>

      <section class="section split rooms" id="work" aria-labelledby="work-title">
        <div>
          <p class="eyebrow">Advisory focus</p>
          <h2 id="work-title">Bitcoin is the center of gravity, but not always the only question.</h2>
          <p class="section-note">The work is usually high-context and high-trust: making complex opportunities clear enough that the right people can decide, fund, approve, partner or move.</p>
        </div>
        <div class="room-grid">
          {rooms.map((room) => (
            <article class="room-card">
              <p class="room-label">{room.label}</p>
              <h3>{room.title}</h3>
              <p>{room.copy}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="practice" aria-labelledby="practice-title">
        <div class="section-heading">
          <p class="eyebrow">Practice areas</p>
          <h2 id="practice-title">Where I help.</h2>
        </div>
        <div class="practice-grid">
          {practiceAreas.map((area) => (
            <article class="practice-card">
              <span class="practice-number">{area.number}</span>
              <h3>{area.title}</h3>
              <p>{area.copy}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section method" aria-labelledby="method-title">
        <div class="section-heading narrow">
          <p class="eyebrow">How I work</p>
          <h2 id="method-title">Start with the real constraint.</h2>
          <p class="body-copy">Sometimes the constraint is product. Sometimes regulation, capital, risk, timing, ownership, incentives, trust or simply the wrong story for the room. I try to make the constraint visible, then help build the next move around it.</p>
          <p class="body-copy">Engagements are selective by design. I work with a limited number of clients at a time, where the question is important enough to justify senior attention and the work can create clear strategic or commercial value.</p>
        </div>
      </section>

      <section class="section about-section" id="about" aria-labelledby="about-title">
        <div class="about-layout">
          <div class="about-copy">
            <p class="eyebrow">About</p>
            <h2 id="about-title">Arnold Sternberg</h2>
            <p>I work where Bitcoin, capital and financial infrastructure meet, with a focus on strategy, positioning and execution.</p>
            <p>I have worked across consulting, investment management, family offices and regulated digital asset infrastructure, including senior and entrepreneurial roles with Sygnum Bank, BitBox and aeris CAPITAL, now Calibrium.</p>
            <p>My independent advisory work focuses on Bitcoin infrastructure, capital strategy and institutional adoption, supported by private operating systems for research and execution.</p>
            <p><a class="text-link" href="https://www.linkedin.com/in/arnoldsternberg/" target="_blank" rel="noreferrer">LinkedIn profile</a></p>
          </div>
          <figure class="portrait-frame">
            <img src="/images/arnold-sternberg-bw.png" alt="Arnold Sternberg" />
          </figure>
        </div>
      </section>

      <section class="contact" id="contact" aria-labelledby="contact-title">
        <div>
          <p class="eyebrow">Contact</p>
          <h2 id="contact-title">See a fit?</h2>
          <p>Send a short note about what you are building, deciding, or trying to understand.</p>
          <p>It helps to start with the situation, the decision, and why now.</p>
        </div>
        <a class="button button-dark" href="mailto:info@strnbrg.com?subject=Strategic%20conversation">Email Arnold</a>
        <p class="disclaimer">No legal, tax, or regulated investment advice.</p>
      </section>
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
